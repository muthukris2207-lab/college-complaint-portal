{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/cron/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/cron/escalate.php",
      "dest": "/api/cron/escalate.php"
    },
    {
      "src": "/login.php",
      "dest": "/api/login.php"
    },
    {
      "src": "/logout.php",
      "dest": "/api/logout.php"
    },
    {
      "src": "/track.php",
      "dest": "/api/track.php"
    },
    {
      "src": "/dashboard_staff.php",
      "dest": "/api/dashboard_staff.php"
    },
    {
      "src": "/dashboard_hod.php",
      "dest": "/api/dashboard_hod.php"
    },
    {
      "src": "/dashboard_principal.php",
      "dest": "/api/dashboard_principal.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
